{
  "name": "ExplorarSection",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Clave \u00fanica de la secci\u00f3n (slug)"
    },
    "label": {
      "type": "string",
      "description": "Nombre visible de la secci\u00f3n"
    },
    "order": {
      "type": "number",
      "default": 0,
      "description": "Orden de aparici\u00f3n en la p\u00e1gina"
    },
    "is_active": {
      "type": "boolean",
      "default": true,
      "description": "Si la secci\u00f3n est\u00e1 visible"
    },
    "section_type": {
      "type": "string",
      "enum": [
        "standard",
        "top10"
      ],
      "default": "standard",
      "description": "Tipo de visualizaci\u00f3n: fila est\u00e1ndar o Top 10 estilo Netflix"
    }
  },
  "required": [
    "key",
    "label"
  ]
}
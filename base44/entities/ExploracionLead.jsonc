    "status": {
      "type": "string",
      "enum": [
        "Alta intenci\u00f3n",
        "Interesado",
        "No listo"
      ],
      "default": "Interesado",
      "description": "Clasificaci\u00f3n autom\u00e1tica del lead"
    }
  },
  "required": [
    "nombre",
    "apellido",
    "nombre_artistico",
    "email",
    "telefono",
    "pais_nacimiento",
    "pais_residencia",
    "direccion",
    "instagram",
    "tiktok",
    "spotify",
    "youtube",
